APP_ENV=test
APP_HOST=127.0.0.1
APP_PORT=8000

DATABASE_URL=postgresql://app:app@127.0.0.1:5432/assistant
REDIS_URL=redis://127.0.0.1:6379/0
N8N_BASE_URL=http://127.0.0.1:5678

LOCAL_LLM_PROVIDER=mlx
LOCAL_LLM_BASE_URL=http://127.0.0.1:1235/v1
LOCAL_LLM_MODEL=lmstudio-community/LFM2-24B-A2B-MLX-4bit
LOCAL_LLM_TIMEOUT_SECONDS=30
LOCAL_LLM_PREWARM_ENABLED=false
LOCAL_LLM_STRUCTURED_EXTRACTION_ENABLED=true
LOCAL_LLM_STRUCTURED_EXTRACTION_BASE_URL=http://127.0.0.1:1235/v1
LOCAL_LLM_STRUCTURED_EXTRACTION_MODEL=lmstudio-community/LFM2-24B-A2B-MLX-4bit
LOCAL_LLM_STRUCTURED_EXTRACTION_TIMEOUT_SECONDS=30

EXTERNAL_LLM_ENABLED=false
EXTERNAL_LLM_PROVIDER=openai
EXTERNAL_LLM_BASE_URL=https://api.openai.com/v1
EXTERNAL_LLM_API_KEY=
EXTERNAL_LLM_MODEL=gpt-4o-mini
EXTERNAL_LLM_TIMEOUT_SECONDS=60
EXTERNAL_LLM_FALLBACK_ONLY=true
EXTERNAL_LLM_STRUCTURED_EXTRACTION_ENABLED=false
EXTERNAL_LLM_STRUCTURED_EXTRACTION_MODEL=

WEB_SEARCH_ENABLED=false
TAVILY_API_KEY=

API_KEY=
RATE_LIMIT_CHAT=1000/minute
RATE_LIMIT_DEFAULT=1000/minute
