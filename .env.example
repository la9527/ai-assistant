APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
WORKER_LOG_LEVEL=INFO
# 개인 운영 기준으로 관리자 로그인 없이 바로 쓰려면 아래 3개 값을 비워 둔다.
# 관리자 로그인 보호를 켜려면 ADMIN_USERNAME, ADMIN_PASSWORD를 함께 설정하고,
# 운영 안정성을 위해 ADMIN_SESSION_SECRET도 같이 넣는다.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_SECONDS=43200

DATABASE_URL=postgresql://app:app@postgres:5432/assistant
REDIS_URL=redis://redis:6379/0
N8N_BASE_URL=http://n8n:5678
N8N_WEBHOOK_PATH=webhook/assistant-automation
N8N_CALENDAR_CREATE_WEBHOOK_PATH=webhook/assistant-calendar-create
N8N_CALENDAR_UPDATE_WEBHOOK_PATH=webhook/assistant-calendar-update
N8N_CALENDAR_DELETE_WEBHOOK_PATH=webhook/assistant-calendar-delete
N8N_GMAIL_WEBHOOK_PATH=webhook/assistant-gmail-summary
N8N_GMAIL_DRAFT_WEBHOOK_PATH=webhook/assistant-gmail-draft
N8N_GMAIL_SEND_WEBHOOK_PATH=webhook/assistant-gmail-send
N8N_GMAIL_REPLY_WEBHOOK_PATH=webhook/assistant-gmail-reply
N8N_WEBHOOK_TOKEN=
DB_SQLITE_POOL_SIZE=2
N8N_EDITOR_BASE_URL=http://127.0.0.1:5678
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=false
N8N_HOST=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_RUNNERS_ENABLED=true

# Ollama 예시: http://host.docker.internal:11434/v1
# MLX base chat 예시: http://host.docker.internal:1235/v1
LOCAL_LLM_BASE_URL=http://host.docker.internal:1235/v1
LOCAL_LLM_PROVIDER=mlx
LOCAL_LLM_MODEL=lmstudio-community/LFM2-24B-A2B-MLX-4bit
LOCAL_LLM_TIMEOUT_SECONDS=90
LOCAL_LLM_PREWARM_ENABLED=true
LOCAL_LLM_STRUCTURED_EXTRACTION_ENABLED=true
LOCAL_LLM_STRUCTURED_EXTRACTION_BASE_URL=http://host.docker.internal:1235/v1
LOCAL_LLM_STRUCTURED_EXTRACTION_MODEL=lmstudio-community/LFM2-24B-A2B-MLX-4bit
LOCAL_LLM_STRUCTURED_EXTRACTION_TIMEOUT_SECONDS=25
LOCAL_LLM_STRUCTURED_EXTRACTION_TARGETS=calendar_create,calendar_update,calendar_delete,gmail_draft,gmail_send,gmail_reply,gmail_thread_reply
BROWSER_RUNNER_BASE_URL=http://browser-runner:8080
MACOS_AUTOMATION_BASE_URL=http://host.docker.internal:8091

# Cloudflare Tunnel for public Kakao webhook ingress
CLOUDFLARE_TUNNEL_TOKEN=
# Example: https://kakao-assistant.example.com
KAKAO_PUBLIC_BASE_URL=
# Example: macmini.tailnet.ts.net
TAILSCALE_HOSTNAME=

# Guacamole browser remote desktop over Tailscale
GUACAMOLE_USERNAME=operator
# Required for Guacamole login. Leave empty only if you intend startup to fail until set.
GUACAMOLE_PASSWORD=change-me-now
GUACAMOLE_CONNECTION_NAME=Mac Mini Desktop
GUACAMOLE_VNC_HOST=host.docker.internal
GUACAMOLE_VNC_PORT=5900
GUACAMOLE_VNC_USERNAME=
GUACAMOLE_VNC_USE_LOGIN_PASSWORD=true
GUACAMOLE_VNC_PASSWORD=
GUACAMOLE_VNC_COLOR_DEPTH=16
GUACAMOLE_VNC_COMPRESS_LEVEL=6
GUACAMOLE_VNC_QUALITY_LEVEL=5
GUACAMOLE_VNC_DISABLE_DISPLAY_RESIZE=false
# VNC audio is off by default. Keep false unless you separately configure PulseAudio on the VNC host.
GUACAMOLE_VNC_ENABLE_AUDIO=false
# Optional. Example: tight zrle hextile copyrect raw
GUACAMOLE_VNC_ENCODINGS=
GUACD_LOG_LEVEL=info

# Slack Events API용 Bot token 예시: xoxb-...
SLACK_BOT_TOKEN=
# 현재 Events API 경로에서는 필수 아님. Socket Mode 확장 시 사용.
SLACK_APP_TOKEN=
# Slack 앱 Basic Information의 Signing Secret 값
SLACK_SIGNING_SECRET=
# 멘션 없이 반응할 Slack 채널 이름 또는 channel id, 여러 개면 쉼표로 구분
SLACK_AUTO_RESPONSE_CHANNELS=C0AM7DH46NL

POSTGRES_DB=assistant
POSTGRES_USER=app
POSTGRES_PASSWORD=app
