APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
WORKER_LOG_LEVEL=INFO

DATABASE_URL=postgresql://app:app@postgres:5432/assistant
REDIS_URL=redis://redis:6379/0
N8N_BASE_URL=http://n8n:5678
N8N_WEBHOOK_PATH=webhook/assistant-automation
N8N_CALENDAR_CREATE_WEBHOOK_PATH=webhook/assistant-calendar-create
N8N_CALENDAR_UPDATE_WEBHOOK_PATH=webhook/assistant-calendar-update
N8N_CALENDAR_DELETE_WEBHOOK_PATH=webhook/assistant-calendar-delete
N8N_GMAIL_WEBHOOK_PATH=webhook/assistant-gmail-summary
N8N_GMAIL_DRAFT_WEBHOOK_PATH=webhook/assistant-gmail-draft
N8N_GMAIL_SEND_WEBHOOK_PATH=webhook/assistant-gmail-send
N8N_GMAIL_REPLY_WEBHOOK_PATH=webhook/assistant-gmail-reply
N8N_WEBHOOK_TOKEN=
DB_SQLITE_POOL_SIZE=2
N8N_EDITOR_BASE_URL=http://127.0.0.1:5678
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=false
N8N_HOST=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_RUNNERS_ENABLED=true

# Ollama 예시: http://host.docker.internal:11434/v1
# LM Studio 예시: http://host.docker.internal:1234/v1
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_MODEL=qwen3:8b

# Slack Events API용 Bot token 예시: xoxb-...
SLACK_BOT_TOKEN=
# 현재 Events API 경로에서는 필수 아님. Socket Mode 확장 시 사용.
SLACK_APP_TOKEN=
# Slack 앱 Basic Information의 Signing Secret 값
SLACK_SIGNING_SECRET=

POSTGRES_DB=assistant
POSTGRES_USER=app
POSTGRES_PASSWORD=app
