    {
      "parameters": {
        "jsCode": "const request = $('Normalize Send Request').first().json;\nconst sent = $json;\nconst reply = `${request.send_to}로 메일을 발송했습니다. 제목은 '${request.subject}' 입니다.`;\nreturn [{ json: { reply, action: 'gmail-send', message_id: String(sent.id ?? '') } }];"
      },
