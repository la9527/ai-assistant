    {
      "parameters": {
        "jsCode": "const payload = $json.body ?? $json;\nif (!payload.send_to || !payload.subject || !payload.message) {\n  return [{ json: { reply: '메일 초안 payload가 올바르지 않습니다.', action: 'gmail-draft-error' } }];\n}\nreturn [{ json: { send_to: String(payload.send_to), subject: String(payload.subject), message: String(payload.message), email_type: String(payload.email_type ?? 'text'), cc_list: String(payload.cc_list ?? ''), bcc_list: String(payload.bcc_list ?? '') } }];"
      },
      "id": "normalize-gmail-draft-node",
      "name": "Normalize Draft Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [520, 260]
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "resource": "draft",
        "operation": "create",
        "subject": "={{ $json.subject }}",
        "emailType": "={{ $json.email_type }}",
        "message": "={{ $json.message }}",
        "options": {
          "sendTo": "={{ $json.send_to }}",
          "ccList": "={{ $json.cc_list }}",
          "bccList": "={{ $json.bcc_list }}"
        }
      },
      "id": "create-gmail-draft-node",
      "name": "Create Gmail Draft",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [820, 260],
