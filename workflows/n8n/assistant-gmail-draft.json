        "gmailOAuth2": {
          "id": "uwgSMn8aAz0uOjq6",
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const request = $('Normalize Draft Request').first().json;\nconst draft = $json;\nconst reply = `${request.send_to} 수신 메일 초안을 작성했습니다. 제목은 '${request.subject}' 입니다.`;\nreturn [{ json: { reply, action: 'gmail-draft', draft_id: String(draft.id ?? '') } }];"
      },
