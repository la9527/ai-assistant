        "jsCode": "const request = $('Reply Target Exists?').first().json;\nconst replyModeLabel = request.reply_mode === 'thread' ? 'thread 이어쓰기' : '메일 회신';\nconst targetLabel = request.subject || request.matched_subject || request.sender || request.matched_sender || request.resolved_thread_id || request.resolved_message_id;\nreturn [{ json: { reply: `${replyModeLabel}을 실행했습니다. 대상은 '${targetLabel}' 입니다.`, action: 'gmail-reply', thread_id: String($json.threadId || request.resolved_thread_id || ''), message_id: String($json.id || request.resolved_message_id || '') } }];"
