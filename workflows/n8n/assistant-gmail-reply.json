      "parameters": {
        "jsCode": "const request = $('Normalize Reply Request').first().json;\nconst messages = $input.all().map((item) => item.json).filter((mail) => mail && (mail.id || mail.threadId));\nif (!messages.length) {\n  return [{ json: { ...request, resolved_thread_id: '', resolved_message_id: '' } }];\n}\nconst target = messages[0];\nreturn [{ json: { ...request, resolved_thread_id: String(target.threadId || request.thread_id || ''), resolved_message_id: String(target.id || request.message_id || ''), matched_subject: String(target.subject || request.subject || ''), matched_sender: String(target.from?.text || request.sender || '') } }];"
      },
