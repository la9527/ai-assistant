        "jsCode": "const payload = $json.body ?? $json;\nif (!payload.message) {\n  return [{ json: { reply: '메일 회신 payload가 올바르지 않습니다.', action: 'gmail-reply-error' } }];\n}\nconst searchQuery = String(payload.search_query ?? '').trim();\nreturn [{ json: { reply_mode: String(payload.reply_mode ?? 'reply'), message: String(payload.message), email_type: String(payload.email_type ?? 'text'), thread_id: String(payload.thread_id ?? ''), message_id: String(payload.message_id ?? ''), subject: String(payload.subject ?? ''), sender: String(payload.sender ?? ''), search_query: searchQuery, cc_list: String(payload.cc_list ?? ''), bcc_list: String(payload.bcc_list ?? ''), direct_target: Boolean(payload.thread_id && payload.message_id), reply_to_sender_only: String(payload.reply_mode ?? 'reply') !== 'thread' } }];"
